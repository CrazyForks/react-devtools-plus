{
  "compilerOptions": {
    "target": "es2017",
    "jsx": "react-jsx",
    "lib": ["esnext", "dom"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "@react-devtools-plus/shared": ["./packages/shared/src/index.ts"],
      "@react-devtools-plus/kit": ["./packages/react-devtools-kit/src/index.ts"],
      "@react-devtools-plus/client": ["./packages/react-devtools-client/src/index.ts"],
      "@react-devtools-plus/overlay": ["./packages/react-devtools-overlay/src/index.ts"],
      "react-devtools-plus": ["./packages/react-devtools/src/index.ts"],
      "react-tracer": ["./packages/react-tracer/src/index.ts"],
      "react-tracer/client/record": ["./packages/react-tracer/src/client/record.ts"],
      "react-tracer/client/listeners": ["./packages/react-tracer/src/client/listeners.ts"],
      "react-tracer/client/overlay": ["./packages/react-tracer/src/client/overlay.ts"],
      "react-tracer/client/open-in-editor": ["./packages/react-tracer/src/client/open-in-editor.ts"],
      "react-tracer/transform": ["./packages/react-tracer/src/transform.ts"],
      "react-tracer/middleware": ["./packages/react-tracer/src/middleware.ts"]
    },
    "resolveJsonModule": true,
    "types": [
      "chrome",
      "vite/client",
      "vitest/globals"
    ],
    "allowJs": true,
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": false,
    // We use tsup/vite instead of tsc to build the package, so we don't need to care about this option.
    // Add outDir option to avoid tsconfig error in monorepo.
    "outDir": "dist",
    "esModuleInterop": true
  },
  "exclude": [
    "**/vite/src/overlay/**",
    "**/dist/**",
    "**/node_modules/**",
    "**/**/*.js"
  ]
}
