{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "rootDir": "src",
    "outDir": "dist",
    "baseUrl": ".",
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "paths": {
      "~web/*": ["src/web/*"],
      "~core/*": ["src/core/*"]
    }
  },
  "include": ["src/**/*", "worker-plugin.ts", "global.d.ts"],
  "exclude": ["dist", "node_modules"]
}
